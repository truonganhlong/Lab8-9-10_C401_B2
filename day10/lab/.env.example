# Day 10 Lab — copy thành .env và điền nếu cần
#   cp .env.example .env

# ChromaDB (khuyến nghị tách collection khỏi Day 09)
CHROMA_DB_PATH=./chroma_db_jina
CHROMA_COLLECTION=day10_kb

# Embedding provider (Jina v5, sentence-transformers local, hoặc hashing offline cho smoke test)
EMBEDDING_PROVIDER=jina
EMBEDDING_MODEL=jina-embeddings-v5-text-small
JINA_API_KEY=
JINA_PASSAGE_TASK=retrieval.passage
JINA_QUERY_TASK=retrieval.query
HASH_EMBED_DIM=384

# Freshness SLA (giờ) — dùng trong monitoring/freshness_check.py
FRESHNESS_SLA_HOURS=24

# Tuỳ chọn: OpenAI chỉ cần nếu nhóm mở rộng eval bằng LLM-judge
# OPENAI_API_KEY=
